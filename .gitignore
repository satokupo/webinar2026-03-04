# === 除外（最小限） ===

# OS
.DS_Store
._*

# Node.js
node_modules/

# Python
__pycache__/
*.py[cod]

# Claude Code（ユーザー固有）
**/.claude/settings.local.json
.claude/plans/
**/.claude/plans/
.claude/temp/

# Astro キャッシュ
**/.astro/

# === ホワイトリスト（グローバル除外の上書き） ===
# グローバル gitignore で *.mp3 等が除外されるユーザー向け
!.claude/skills/**/sound/*.mp3
